pkgname=cryptopad
pkgver=@PROJECT_VERSION@
pkgrel=1
pkgdesc="Rich-text editor with Arsenic V1 encryption, fully interoperable with the Arsenic application"
arch=('x86_64')
url="https://github.com/Antidote1911/cryptopad"
license=('GPL3')
provides=('cryptopad')
conflicts=('cryptopad-git' 'cryptopad-appimage')
depends=('qt6-base')
makedepends=('cmake' 'ninja' 'rust' 'git')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/Antidote1911/${pkgname}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"
    cmake -S . -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --parallel
}

package() {
    cd "${pkgname}-${pkgver}"
    DESTDIR="${pkgdir}" cmake --install build --component cryptopad
}
