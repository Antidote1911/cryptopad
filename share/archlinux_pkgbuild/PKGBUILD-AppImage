# Generated by CMake from PKGBUILD-AppImage.in — do not edit this file directly.
#
# Installe le binaire AppImage pré-compilé depuis la dernière release GitHub.
# Toutes les dépendances (Qt, Botan, etc.) sont embarquées dans l'AppImage.
# La variable APPIMAGE_EXTRACT_AND_RUN évite d'avoir besoin de fuse2 au runtime.

pkgname=cryptopad-appimage
pkgver=1.0.2
pkgrel=1
pkgdesc="Rich-text editor with triple-layer file encryption (AppImage pre-built)"
arch=('x86_64')
url="https://github.com/Antidote1911/cryptopad"
license=('GPL3')
provides=('cryptopad')
conflicts=('cryptopad' 'cryptopad-git')
depends=()
options=('!strip')
noextract=("cryptopad-${pkgver}-linux-x86_64.AppImage")
source=("cryptopad-${pkgver}-linux-x86_64.AppImage::https://github.com/Antidote1911/cryptopad/releases/download/v${pkgver}/cryptopad-${pkgver}-linux-x86_64.AppImage")
sha256sums=('SKIP')

prepare() {
    chmod +x "cryptopad-${pkgver}-linux-x86_64.AppImage"
    # Extraire le squashfs pour récupérer le .desktop et l'icône
    # --appimage-extract ne nécessite pas FUSE
    "./cryptopad-${pkgver}-linux-x86_64.AppImage" --appimage-extract > /dev/null
    mv squashfs-root cryptopad-squashfs
}

package() {
    # AppImage dans /opt
    install -Dm755 "cryptopad-${pkgver}-linux-x86_64.AppImage" \
        "${pkgdir}/opt/cryptopad/cryptopad.AppImage"

    # Script wrapper : utilise APPIMAGE_EXTRACT_AND_RUN pour éviter fuse2
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/cryptopad" << 'EOF'
#!/bin/sh
exec env APPIMAGE_EXTRACT_AND_RUN=1 /opt/cryptopad/cryptopad.AppImage "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/cryptopad"

    # Intégration bureau extraite de l'AppImage
    install -Dm644 "cryptopad-squashfs/cryptopad.desktop" \
        "${pkgdir}/usr/share/applications/cryptopad.desktop"
    install -Dm644 "cryptopad-squashfs/cryptopad.png" \
        "${pkgdir}/usr/share/icons/hicolor/256x256/apps/cryptopad.png"
}
